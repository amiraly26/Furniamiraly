PORT=1337
PAYLOAD_SECRET=replace-with-a-long-random-secret

# Use Neon, Supabase, Railway, or another hosted Postgres database.
# You can fill this in later when you create the database.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# Frontend URL for CORS/CSRF while developing locally.
FRONTEND_URL=http://localhost:3000

# Public URL of this Payload app. Change this after deployment.
NEXT_PUBLIC_PAYLOAD_URL=http://localhost:1337
